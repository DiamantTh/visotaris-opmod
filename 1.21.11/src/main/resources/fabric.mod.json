{
  "schemaVersion": 1,
  "id": "noopmod",
  "version": "${version}",
  "name": "Visotaris OPMod",
  "description": "OPSUCHT-Client-Komfort-Mod: Marktpreise, Jobtracker, HUD, Amboss-Normalisierung, OffhandBlocker u.v.m.",
  "authors": [
    "DiamantTh"
  ],
  "contact": {
    "sources": "https://git.diath.systems/DiamantTh/visotaris-opmod"
  },
  "license": "AGPL-3.0-or-later",
  "icon": "assets/noopmod/icon.png",
  "accessWidener": "noopmod.accesswidener",

  "environment": "client",

  "entrypoints": {
    "client": [
      "systems.diath.noopmod.NoOpModClient"
    ],
    "modmenu": [
      "systems.diath.noopmod.config.ModMenuApiImpl"
    ]
  },

  "mixins": [
    "noopmod.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=0.18.5",
    "fabric-api": "*",
    "fabric-language-kotlin": ">=1.12.0",
    "minecraft": "~1.21.11",
    "java": ">=21"
  },

  "suggests": {
    "modmenu": "*"
  }
}
